<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recipe Nest - Home</title>
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
    />
    <link rel="stylesheet" href="/css/home.css" />
  </head>
  <body>
    <!-- Header -->
    <header class="bg-dark text-white py-3">
      <div class="container d-flex justify-content-between align-items-center">
        <h1 class="h3">Recipe Nest</h1>
        <nav>
          <ul class="nav">
            <li class="nav-item">
              <a class="nav-link text-white" href="#cooking-tips"
                >Cooking Tips</a
              >
            </li>
            <li class="nav-item">
              <a class="nav-link text-white" href="#latest-recipes"
                >Latest Recipes</a
              >
            </li>
            <li class="nav-item">
              <a class="nav-link text-white" href="#faq">FAQs</a>
            </li>
            <li class="nav-item">
              <a class="nav-link text-white" href="#community">Community</a>
            </li>
            <!-- Aligned Logout Properly -->
            <% if(!currentuser) { %>
            <li class="nav-item">
              <form action="/login" method="post" class="d-inline-block">
                <button type="submit" class="btn btn-light">Login</button>
              </form>
            </li>
            <% } else {%>
            <li class="nav-item">
              <form action="/logout" method="post" class="d-inline-block">
                <button type="submit" class="btn btn-light">Logout</button>
              </form>
            </li>
            <% } %>
          </ul>
        </nav>
      </div>
    </header>

    <!-- Hero Section -->
    <section class="hero-section text-center text-white">
      <div class="container">
        <h1>Welcome to Recipe Nest</h1>
        <p>Discover delicious recipes and expert cooking tips.</p>
        <a href="/recipe" class="btn btn-light text-muted">Explore Recipes</a>
      </div>
    </section>

    <!-- latest recipe section -->
    <section
      id="latest-recipes"
      class="latest-recipes section-container text-center"
    >
      <div class="container">
        <h2 class="section-title">Latest Recipes</h2>
        <div
          id="latestRecipesCarousel"
          class="carousel slide"
          data-bs-ride="carousel"
        >
          <div class="carousel-inner">
            <!-- Slide 1 -->
            <div class="carousel-item active">
              <div class="row">
                <div class="col-md-4">
                  <div class="recipe-card">
                    <img
                      src="/image/chickencurry.jpg"
                      class="recipe-image"
                      alt="Spicy Chicken Curry"
                    />
                    <h4 class="recipe-title">Spicy Chicken Curry</h4>
                    <p class="recipe-description">
                      A flavorful and aromatic curry made with tender chicken,
                      rich spices, and a spicy kick.
                    </p>
                    <div class="recipe-rating text-muted">
                      Rating: <strong>4.8⭐</strong>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="recipe-card">
                    <img
                      src="/image/pasta.jpg"
                      class="recipe-image"
                      alt="Vegetarian Pasta"
                    />
                    <h4 class="recipe-title">Vegetarian Pasta</h4>
                    <p class="recipe-description">
                      A light yet delicious pasta dish loaded with fresh
                      vegetables, olive oil, and herbs.
                    </p>
                    <div class="recipe-rating text-muted">
                      Rating: <strong>4.7⭐</strong>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="recipe-card">
                    <img
                      src="/image/smoothie.jpg"
                      class="recipe-image"
                      alt="Healthy Smoothie"
                    />
                    <h4 class="recipe-title">Healthy Smoothie</h4>
                    <p class="recipe-description">
                      A refreshing smoothie packed with fruits, yogurt, and
                      nutrients for a healthy start.
                    </p>
                    <div class="recipe-rating text-muted">
                      Rating: <strong>4.3⭐</strong>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Slide 2 -->
            <div class="carousel-item">
              <div class="row">
                <div class="col-md-4">
                  <div class="recipe-card">
                    <img
                      src="/image/grilledsalmon.jpg"
                      class="recipe-image"
                      alt="Grilled Salmon"
                    />
                    <h4 class="recipe-title">Grilled Salmon</h4>
                    <p class="recipe-description">
                      Perfectly grilled salmon with a lemon butter glaze for a
                      delightful taste.
                    </p>
                    <div class="recipe-rating text-muted">
                      Rating: <strong>4.6⭐</strong>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="recipe-card">
                    <img
                      src="/image/garlicbread.webp"
                      class="recipe-image"
                      alt="Garlic Bread"
                    />
                    <h4 class="recipe-title">Garlic Bread</h4>
                    <p class="recipe-description">
                      Crispy and flavorful garlic bread, perfect as a side dish.
                    </p>
                    <div class="recipe-rating text-muted">
                      Rating: <strong>4.9⭐</strong>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="recipe-card">
                    <img
                      src="/image/mangosalad.jpg"
                      class="recipe-image"
                      alt="Mango Salad"
                    />
                    <h4 class="recipe-title">Mango Salad</h4>
                    <p class="recipe-description">
                      A refreshing tropical mango salad with citrus dressing.
                    </p>
                    <div class="recipe-rating text-muted">
                      Rating: <strong>4.7⭐</strong>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Slide 3 -->
            <div class="carousel-item">
              <div class="row">
                <div class="col-md-4">
                  <div class="recipe-card">
                    <img
                      src="/image/homemadepizza.jpg"
                      class="recipe-image"
                      alt="Homemade Pizza"
                    />
                    <h4 class="recipe-title">Homemade Pizza</h4>
                    <p class="recipe-description">
                      Delicious homemade pizza with fresh toppings and cheesy
                      goodness.
                    </p>
                    <div class="recipe-rating text-muted">
                      Rating: <strong>4.9⭐</strong>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="recipe-card">
                    <img
                      src="/image/veganbowl.webp"
                      class="recipe-image"
                      alt="Vegan Power Bowl"
                    />
                    <h4 class="recipe-title">Vegan Power Bowl</h4>
                    <p class="recipe-description">
                      A healthy mix of grains, veggies, and proteins in one
                      nourishing bowl.
                    </p>
                    <div class="recipe-rating text-muted">
                      Rating: <strong>4.9⭐</strong>
                    </div>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="recipe-card">
                    <img
                      src="/image/strawberrydelight.jpg"
                      class="recipe-image"
                      alt="Strawberry Delight"
                    />
                    <h4 class="recipe-title">Strawberry Delight</h4>
                    <p class="recipe-description">
                      A sweet and creamy strawberry dessert, perfect for any
                      occasion.
                    </p>
                    <div class="recipe-rating text-muted">
                      Rating: <strong>4.8⭐</strong>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <!-- Additional Slides place -->
          </div>
          <!-- Carousel Controls -->
          <button
            class="carousel-control-prev"
            type="button"
            data-bs-target="#latestRecipesCarousel"
            data-bs-slide="prev"
          >
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
          </button>
          <button
            class="carousel-control-next"
            type="button"
            data-bs-target="#latestRecipesCarousel"
            data-bs-slide="next"
          >
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </section>

    <!-- meal planner -->
    <section
      id="meal-planner"
      class="meal-planner section-container text-center mt-4 mb-4"
    >
      <div class="container p-5">
        <h2 class="section-title">Plan Your Meals Effortlessly</h2>
        <p class="section-description">
          Use our dynamic meal planner to create a personalized meal plan that
          suits your taste and dietary needs.
        </p>
        <a href="meal" class="btn btn-primary">Start Meal Planning</a>
      </div>
    </section>

    <!-- Cooking Tips Section -->
    <section
      id="cooking-tips"
      class="cooking-tips section-container text-center"
    >
      <div class="container">
        <h2 class="section-title">Cooking Tips</h2>
        <div
          id="cookingTipsCarousel"
          class="carousel slide"
          data-bs-ride="carousel"
        >
          <div class="carousel-inner">
            <!-- Slide 1 -->
            <div class="carousel-item active">
              <div class="row">
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip1.jpg"
                      class="tip-image"
                      alt="Perfect Pasta"
                    />
                    <h4 class="tip-title">Control Heat Properly</h4>
                    <p class="tip-description">
                      Understand when to use low, medium, or high heat to
                      prevent overcooking or burning.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip2.jpg"
                      class="tip-image"
                      alt="Knife Skills"
                    />
                    <h4 class="tip-title">Knife Skills</h4>
                    <p class="tip-description">
                      Use a sharp knife and proper technique for safety and
                      precision.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip3.jpg"
                      class="tip-image"
                      alt="Spices & Herbs"
                    />
                    <h4 class="tip-title">Spices & Herbs</h4>
                    <p class="tip-description">
                      Toast spices for enhanced flavor and aroma in your dishes.
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Slide 2 -->
            <div class="carousel-item">
              <div class="row">
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip4.jpg"
                      class="tip-image"
                      alt="Fresh Ingredients"
                    />
                    <h4 class="tip-title">Use Fresh Ingredients</h4>
                    <p class="tip-description">
                      Fresh ingredients enhance the taste and nutrition of your
                      meals.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip5.jpg"
                      class="tip-image"
                      alt="Taste as You Go"
                    />
                    <h4 class="tip-title">Taste as You Go</h4>
                    <p class="tip-description">
                      Adjust seasoning gradually while cooking for a balanced
                      flavor.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip6.jpg"
                      class="tip-image"
                      alt="Choose the Right Oil"
                    />
                    <h4 class="tip-title">Choose the Right Oil</h4>
                    <p class="tip-description">
                      Use oils with a high smoke point for frying and lighter
                      oils for dressings.
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Slide 3 -->
            <div class="carousel-item">
              <div class="row">
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip7.jpg"
                      class="tip-image"
                      alt="Rest Meat After Cooking"
                    />
                    <h4 class="tip-title">Rest Meat After Cooking</h4>
                    <p class="tip-description">
                      Let cooked meat rest to retain juices for better flavor.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip8.jpg"
                      class="tip-image"
                      alt="Accurate Baking"
                    />
                    <h4 class="tip-title">Accurate Measurements</h4>
                    <p class="tip-description">
                      Use precise measurements in baking for consistent results.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip9.jpg"
                      class="tip-image"
                      alt="Homemade Stock"
                    />
                    <h4 class="tip-title">Make Homemade Stock</h4>
                    <p class="tip-description">
                      Prepare your own stock for deeper flavors in soups and
                      sauces.
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Slide 4 -->
            <div class="carousel-item">
              <div class="row">
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip10.jpg"
                      class="tip-image"
                      alt="Seasonal Produce"
                    />
                    <h4 class="tip-title">Use Seasonal Produce</h4>
                    <p class="tip-description">
                      Seasonal produce is fresher, tastier, and often more
                      affordable.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip11.jpg"
                      class="tip-image"
                      alt="Clean as You Cook"
                    />
                    <h4 class="tip-title">Clean as You Cook</h4>
                    <p class="tip-description">
                      Keep your workspace tidy to make cooking more efficient
                      and enjoyable.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip12.jpg"
                      class="tip-image"
                      alt="Save Pasta Water"
                    />
                    <h4 class="tip-title">Save Pasta Water</h4>
                    <p class="tip-description">
                      Use starchy pasta water to thicken and enhance your
                      sauces.
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Slide 5 -->
            <div class="carousel-item">
              <div class="row">
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip13.jpg"
                      class="tip-image"
                      alt="Proper Storage"
                    />
                    <h4 class="tip-title">Proper Storage</h4>
                    <p class="tip-description">
                      Store ingredients correctly to maintain freshness and
                      prevent waste.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip14.jpg"
                      class="tip-image"
                      alt="Don't Overcrowd the Pan"
                    />
                    <h4 class="tip-title">Don't Overcrowd the Pan</h4>
                    <p class="tip-description">
                      Give ingredients space to cook evenly and develop proper
                      texture.
                    </p>
                  </div>
                </div>
                <div class="col-md-4">
                  <div class="tip-card">
                    <img
                      src="/image/tip15.jpg"
                      class="tip-image"
                      alt="Mise en Place"
                    />
                    <h4 class="tip-title">Mise en Place</h4>
                    <p class="tip-description">
                      Prepare ingredients in advance for a smoother cooking
                      process.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Carousel Controls -->
          <button
            class="carousel-control-prev"
            type="button"
            data-bs-target="#cookingTipsCarousel"
            data-bs-slide="prev"
          >
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
          </button>
          <button
            class="carousel-control-next"
            type="button"
            data-bs-target="#cookingTipsCarousel"
            data-bs-slide="next"
          >
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
          </button>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section id="faq" class="faq-section section-container text-center">
      <div class="container">
        <div class="card-style">
          <h2>Frequently Asked Questions</h2>
          <div class="accordion" id="faqAccordion">
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button
                  class="accordion-button"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#faq1"
                >
                  What is Recipe Nest?
                </button>
              </h2>
              <div
                id="faq1"
                class="accordion-collapse collapse"
                data-bs-parent="#faqAccordion"
              >
                <div class="accordion-body">
                  Recipe Nest is an online platform designed to help users
                  discover, save, and share recipes from various cuisines. It
                  provides a structured format to display recipes with
                  ingredients, steps, and descriptions.
                </div>
              </div>
            </div>

            <div class="accordion-item">
              <h2 class="accordion-header">
                <button
                  class="accordion-button"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#faq2"
                >
                  How do I search for recipes?
                </button>
              </h2>
              <div
                id="faq2"
                class="accordion-collapse collapse"
                data-bs-parent="#faqAccordion"
              >
                <div class="accordion-body">
                  You can search for recipes by name, cuisine type, or
                  ingredients. The results will be displayed in a structured
                  format, showing the recipe name, cuisine, ingredients, and
                  steps.
                </div>
              </div>
            </div>

            <div class="accordion-item">
              <h2 class="accordion-header">
                <button
                  class="accordion-button"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#faq3"
                >
                  Is Recipe Nest free to use?
                </button>
              </h2>
              <div
                id="faq3"
                class="accordion-collapse collapse"
                data-bs-parent="#faqAccordion"
              >
                <div class="accordion-body">
                  Yes, Recipe Nest is completely free to use. Users can browse,
                  search, and save recipes without any charges.
                </div>
              </div>
            </div>

            <!-- Fourth FAQ -->
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button
                  class="accordion-button"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#faq4"
                >
                  Can I submit my own recipes?
                </button>
              </h2>
              <div
                id="faq4"
                class="accordion-collapse collapse"
                data-bs-parent="#faqAccordion"
              >
                <div class="accordion-body">
                  Yes! Users can submit their own recipes by filling out a form
                  with the required details, including the recipe name,
                  ingredients, cuisine, and preparation steps.
                </div>
              </div>
            </div>

            <!-- Fifth FAQ -->
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button
                  class="accordion-button"
                  type="button"
                  data-bs-toggle="collapse"
                  data-bs-target="#faq5"
                >
                  Can I filter recipes based on dietary preferences?
                </button>
              </h2>
              <div
                id="faq5"
                class="accordion-collapse collapse"
                data-bs-parent="#faqAccordion"
              >
                <div class="accordion-body">
                  Yes, Recipe Nest allows users to filter recipes based on
                  dietary preferences such as vegetarian, vegan, gluten-free,
                  and more.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Community Section -->
    <section
      id="community"
      class="community-section text-center py-5"
      style="background-color: #fef3e3"
    >
      <div class="container">
        <div class="card-style">
          <img
            src="/image/community.jpg"
            alt="Cooking Community"
            class="img-fluid rounded mb-3"
            style="max-width: 100%; height: 350px; object-fit: cover"
          />
          <h2>Join Our Community</h2>
          <p>
            Share your favorite recipes and be part of our growing food lovers'
            community.
          </p>
          <a href="/community" class="btn btn-light">Go to Community</a>
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="bg-dark text-white text-center py-3">
      <p>&copy; 2025 Recipe Nest. All Rights Reserved.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
